{
  "name": "mocklify",
  "displayName": "Mocklify",
  "description": "Mocklify - Powerful API mocking for VS Code. Create, manage, and run mock servers with ease.",
  "version": "0.1.0",
  "publisher": "sitharaj",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sitharaj88/mocklify"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "mocklify",
    "mock",
    "server",
    "api",
    "testing",
    "rest",
    "http",
    "mocking"
  ],
  "activationEvents": [
    "workspaceContains:.mocklify"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mocklify.createServer",
        "title": "Create Server",
        "category": "Mocklify",
        "icon": "$(add)"
      },
      {
        "command": "mocklify.startServer",
        "title": "Start Server",
        "category": "Mocklify",
        "icon": "$(play)"
      },
      {
        "command": "mocklify.stopServer",
        "title": "Stop Server",
        "category": "Mocklify",
        "icon": "$(debug-stop)"
      },
      {
        "command": "mocklify.startAll",
        "title": "Start All Servers",
        "category": "Mocklify",
        "icon": "$(run-all)"
      },
      {
        "command": "mocklify.stopAll",
        "title": "Stop All Servers",
        "category": "Mocklify",
        "icon": "$(debug-stop)"
      },
      {
        "command": "mocklify.deleteServer",
        "title": "Delete Server",
        "category": "Mocklify",
        "icon": "$(trash)"
      },
      {
        "command": "mocklify.addRoute",
        "title": "Add Route",
        "category": "Mocklify",
        "icon": "$(add)"
      },
      {
        "command": "mocklify.editRoute",
        "title": "Edit Route",
        "category": "Mocklify",
        "icon": "$(edit)"
      },
      {
        "command": "mocklify.deleteRoute",
        "title": "Delete Route",
        "category": "Mocklify",
        "icon": "$(trash)"
      },
      {
        "command": "mocklify.toggleRoute",
        "title": "Toggle Route",
        "category": "Mocklify"
      },
      {
        "command": "mocklify.importOpenApi",
        "title": "Import OpenAPI/Swagger",
        "category": "Mocklify",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mocklify.importPostman",
        "title": "Import Postman Collection",
        "category": "Mocklify",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mocklify.exportServer",
        "title": "Export Server Config",
        "category": "Mocklify",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mocklify.exportLogs",
        "title": "Export Request Logs",
        "category": "Mocklify",
        "icon": "$(export)"
      },
      {
        "command": "mocklify.startRecording",
        "title": "Start Recording",
        "category": "Mocklify",
        "icon": "$(record)"
      },
      {
        "command": "mocklify.stopRecording",
        "title": "Stop Recording",
        "category": "Mocklify",
        "icon": "$(debug-stop)"
      },
      {
        "command": "mocklify.openLogs",
        "title": "Open Request Logs",
        "category": "Mocklify",
        "icon": "$(output)"
      },
      {
        "command": "mocklify.refresh",
        "title": "Refresh",
        "category": "Mocklify",
        "icon": "$(refresh)"
      },
      {
        "command": "mocklify.openDashboard",
        "title": "Open Dashboard",
        "category": "Mocklify",
        "icon": "$(dashboard)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mocklifyExplorer",
          "title": "Mocklify",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "mocklifyExplorer": [
        {
          "id": "mocklifyServers",
          "name": "Servers"
        },
        {
          "id": "mocklifyLogs",
          "name": "Request Logs"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "mocklify.openDashboard",
          "when": "view == mocklifyServers",
          "group": "navigation@1"
        },
        {
          "command": "mocklify.createServer",
          "when": "view == mocklifyServers",
          "group": "navigation@2"
        },
        {
          "command": "mocklify.startAll",
          "when": "view == mocklifyServers",
          "group": "navigation@3"
        },
        {
          "command": "mocklify.stopAll",
          "when": "view == mocklifyServers",
          "group": "navigation@4"
        },
        {
          "command": "mocklify.refresh",
          "when": "view == mocklifyServers",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "mocklify.startServer",
          "when": "view == mocklifyServers && viewItem == server-stopped",
          "group": "inline"
        },
        {
          "command": "mocklify.stopServer",
          "when": "view == mocklifyServers && viewItem == server-running",
          "group": "inline"
        },
        {
          "command": "mocklify.addRoute",
          "when": "view == mocklifyServers && viewItem =~ /^server/",
          "group": "1_routes"
        },
        {
          "command": "mocklify.importOpenApi",
          "when": "view == mocklifyServers && viewItem =~ /^server/",
          "group": "1_routes"
        },
        {
          "command": "mocklify.importPostman",
          "when": "view == mocklifyServers && viewItem =~ /^server/",
          "group": "1_routes"
        },
        {
          "command": "mocklify.exportServer",
          "when": "view == mocklifyServers && viewItem =~ /^server/",
          "group": "3_export"
        },
        {
          "command": "mocklify.exportLogs",
          "when": "view == mocklifyServers && viewItem =~ /^server/",
          "group": "3_export"
        },
        {
          "command": "mocklify.startRecording",
          "when": "view == mocklifyServers && viewItem == server-running",
          "group": "4_recording"
        },
        {
          "command": "mocklify.deleteServer",
          "when": "view == mocklifyServers && viewItem =~ /^server/",
          "group": "9_manage"
        },
        {
          "command": "mocklify.editRoute",
          "when": "view == mocklifyServers && viewItem == route",
          "group": "inline"
        },
        {
          "command": "mocklify.toggleRoute",
          "when": "view == mocklifyServers && viewItem == route",
          "group": "1_toggle"
        },
        {
          "command": "mocklify.deleteRoute",
          "when": "view == mocklifyServers && viewItem == route",
          "group": "2_manage"
        }
      ]
    },
    "configuration": {
      "title": "Mocklify",
      "properties": {
        "mocklify.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start servers when VS Code opens"
        },
        "mocklify.defaultPort": {
          "type": "number",
          "default": 3000,
          "description": "Default port for new Mocklify servers"
        },
        "mocklify.configPath": {
          "type": "string",
          "default": ".mocklify",
          "description": "Path to configuration directory relative to workspace"
        },
        "mocklify.logging.maxEntries": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of log entries to keep"
        },
        "mocklify.logging.includeBody": {
          "type": "boolean",
          "default": true,
          "description": "Include request/response body in logs"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.0",
    "fastify": "^4.24.0",
    "handlebars": "^4.7.8",
    "uuid": "^9.0.1",
    "ws": "^8.14.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  }
}

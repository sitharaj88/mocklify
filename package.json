{
  "name": "specter",
  "displayName": "Specter",
  "description": "Specter - Powerful API mocking for VS Code. Create, manage, and run mock servers with ease.",
  "version": "0.1.0",
  "publisher": "sitharaj",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "specter",
    "mock",
    "server",
    "api",
    "testing",
    "rest",
    "http",
    "mocking"
  ],
  "activationEvents": [
    "workspaceContains:.specter"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "specter.createServer",
        "title": "Create Server",
        "category": "Specter",
        "icon": "$(add)"
      },
      {
        "command": "specter.startServer",
        "title": "Start Server",
        "category": "Specter",
        "icon": "$(play)"
      },
      {
        "command": "specter.stopServer",
        "title": "Stop Server",
        "category": "Specter",
        "icon": "$(debug-stop)"
      },
      {
        "command": "specter.startAll",
        "title": "Start All Servers",
        "category": "Specter",
        "icon": "$(run-all)"
      },
      {
        "command": "specter.stopAll",
        "title": "Stop All Servers",
        "category": "Specter",
        "icon": "$(debug-stop)"
      },
      {
        "command": "specter.deleteServer",
        "title": "Delete Server",
        "category": "Specter",
        "icon": "$(trash)"
      },
      {
        "command": "specter.addRoute",
        "title": "Add Route",
        "category": "Specter",
        "icon": "$(add)"
      },
      {
        "command": "specter.editRoute",
        "title": "Edit Route",
        "category": "Specter",
        "icon": "$(edit)"
      },
      {
        "command": "specter.deleteRoute",
        "title": "Delete Route",
        "category": "Specter",
        "icon": "$(trash)"
      },
      {
        "command": "specter.toggleRoute",
        "title": "Toggle Route",
        "category": "Specter"
      },
      {
        "command": "specter.importOpenApi",
        "title": "Import OpenAPI/Swagger",
        "category": "Specter",
        "icon": "$(cloud-download)"
      },
      {
        "command": "specter.importPostman",
        "title": "Import Postman Collection",
        "category": "Specter",
        "icon": "$(cloud-download)"
      },
      {
        "command": "specter.exportServer",
        "title": "Export Server Config",
        "category": "Specter",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "specter.exportLogs",
        "title": "Export Request Logs",
        "category": "Specter",
        "icon": "$(export)"
      },
      {
        "command": "specter.startRecording",
        "title": "Start Recording",
        "category": "Specter",
        "icon": "$(record)"
      },
      {
        "command": "specter.stopRecording",
        "title": "Stop Recording",
        "category": "Specter",
        "icon": "$(debug-stop)"
      },
      {
        "command": "specter.openLogs",
        "title": "Open Request Logs",
        "category": "Specter",
        "icon": "$(output)"
      },
      {
        "command": "specter.refresh",
        "title": "Refresh",
        "category": "Specter",
        "icon": "$(refresh)"
      },
      {
        "command": "specter.openDashboard",
        "title": "Open Dashboard",
        "category": "Specter",
        "icon": "$(dashboard)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specterExplorer",
          "title": "Specter",
          "icon": "resources/specter.svg"
        }
      ]
    },
    "views": {
      "specterExplorer": [
        {
          "id": "specterServers",
          "name": "Servers"
        },
        {
          "id": "specterLogs",
          "name": "Request Logs"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "specter.openDashboard",
          "when": "view == specterServers",
          "group": "navigation@1"
        },
        {
          "command": "specter.createServer",
          "when": "view == specterServers",
          "group": "navigation@2"
        },
        {
          "command": "specter.startAll",
          "when": "view == specterServers",
          "group": "navigation@3"
        },
        {
          "command": "specter.stopAll",
          "when": "view == specterServers",
          "group": "navigation@4"
        },
        {
          "command": "specter.refresh",
          "when": "view == specterServers",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "specter.startServer",
          "when": "view == specterServers && viewItem == server-stopped",
          "group": "inline"
        },
        {
          "command": "specter.stopServer",
          "when": "view == specterServers && viewItem == server-running",
          "group": "inline"
        },
        {
          "command": "specter.addRoute",
          "when": "view == specterServers && viewItem =~ /^server/",
          "group": "1_routes"
        },
        {
          "command": "specter.importOpenApi",
          "when": "view == specterServers && viewItem =~ /^server/",
          "group": "1_routes"
        },
        {
          "command": "specter.importPostman",
          "when": "view == specterServers && viewItem =~ /^server/",
          "group": "1_routes"
        },
        {
          "command": "specter.exportServer",
          "when": "view == specterServers && viewItem =~ /^server/",
          "group": "3_export"
        },
        {
          "command": "specter.exportLogs",
          "when": "view == specterServers && viewItem =~ /^server/",
          "group": "3_export"
        },
        {
          "command": "specter.startRecording",
          "when": "view == specterServers && viewItem == server-running",
          "group": "4_recording"
        },
        {
          "command": "specter.deleteServer",
          "when": "view == specterServers && viewItem =~ /^server/",
          "group": "9_manage"
        },
        {
          "command": "specter.editRoute",
          "when": "view == specterServers && viewItem == route",
          "group": "inline"
        },
        {
          "command": "specter.toggleRoute",
          "when": "view == specterServers && viewItem == route",
          "group": "1_toggle"
        },
        {
          "command": "specter.deleteRoute",
          "when": "view == specterServers && viewItem == route",
          "group": "2_manage"
        }
      ]
    },
    "configuration": {
      "title": "Specter",
      "properties": {
        "specter.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start servers when VS Code opens"
        },
        "specter.defaultPort": {
          "type": "number",
          "default": 3000,
          "description": "Default port for new Specter servers"
        },
        "specter.configPath": {
          "type": "string",
          "default": ".specter",
          "description": "Path to configuration directory relative to workspace"
        },
        "specter.logging.maxEntries": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of log entries to keep"
        },
        "specter.logging.includeBody": {
          "type": "boolean",
          "default": true,
          "description": "Include request/response body in logs"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.0",
    "fastify": "^4.24.0",
    "handlebars": "^4.7.8",
    "uuid": "^9.0.1",
    "ws": "^8.14.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  }
}
